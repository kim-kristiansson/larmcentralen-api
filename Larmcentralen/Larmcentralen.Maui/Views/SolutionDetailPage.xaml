<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:md="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown"
             x:Class="Larmcentralen.Maui.Views.SolutionDetailPage"
             BackgroundColor="{StaticResource Background}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Back nav -->
        <Grid Grid.Row="0" Padding="24,16" ColumnDefinitions="Auto,*">
            <Label Text="← Tillbaka" 
                   TextColor="{StaticResource Accent}" 
                   FontSize="15"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <ScrollView Grid.Row="1">
            <Grid HorizontalOptions="Fill">
                <VerticalStackLayout WidthRequest="900" HorizontalOptions="Center" Padding="32,8,32,48" Spacing="6">
                    
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{StaticResource Accent}"
                                       HorizontalOptions="Center"
                                       Margin="0,24,0,0" />

                    <!-- Severity badge -->
                    <Border x:Name="SeverityBadge"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 6"
                            Padding="10,6"
                            HorizontalOptions="Start"
                            Margin="0,0,0,4">
                        <Label x:Name="SeverityLabel" FontSize="13" FontAttributes="Bold" />
                    </Border>

                    <!-- Title row with edit button -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label x:Name="TitleLabel" 
                               FontSize="28" 
                               FontAttributes="Bold" 
                               TextColor="{StaticResource Primary}"
                               Grid.Column="0" />
                        <Button Text="Redigera"
                                FontSize="13"
                                TextColor="{StaticResource Accent}"
                                BackgroundColor="Transparent"
                                BorderColor="{StaticResource Accent}"
                                BorderWidth="1"
                                CornerRadius="6"
                                HeightRequest="36"
                                Padding="14,0"
                                Clicked="OnEditTapped"
                                Grid.Column="1"
                                VerticalOptions="Center" />
                        <Button Text="Ta bort"
                                FontSize="13"
                                TextColor="#991B1B"
                                BackgroundColor="Transparent"
                                BorderColor="#FECACA"
                                BorderWidth="1"
                                CornerRadius="6"
                                HeightRequest="36"
                                Padding="14,0"
                                Clicked="OnDeleteTapped"
                                Grid.Column="2"
                                VerticalOptions="Center" />
                    </Grid>

                    <Label x:Name="TimeLabel" 
                           FontSize="15" 
                           TextColor="{StaticResource TextSecondary}" />

                    <BoxView Style="{StaticResource Divider}" Margin="0,20" />

                    <!-- Markdown content directly on page -->
                    <md:MarkdownView x:Name="MarkdownContent" HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>