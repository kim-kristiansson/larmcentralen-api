<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Larmcentralen.Maui.Views.AlarmDetailPage"
             Title="Alarm">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="12">

            <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" />
            <Label x:Name="AlarmCodeLabel" FontSize="14" TextColor="Gray" />

            <Border Padding="8,4" StrokeShape="RoundRectangle 4" HorizontalOptions="Start">
                <Label x:Name="SeverityLabel" FontSize="12" FontAttributes="Bold" />
            </Border>

            <Label x:Name="EquipmentLabel" FontSize="14" TextColor="Gray" />
            <Label x:Name="DescriptionLabel" FontSize="14" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Lösningar" FontSize="18" FontAttributes="Bold" />

            <CollectionView x:Name="SolutionsList"
                            SelectionMode="Single"
                            SelectionChanged="OnSolutionSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,4" Stroke="LightGray" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout>
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" />
                                <Label Text="{Binding EstimatedTime}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="Inga lösningar dokumenterade ännu" TextColor="Gray" FontAttributes="Italic" />
                </CollectionView.EmptyView>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>