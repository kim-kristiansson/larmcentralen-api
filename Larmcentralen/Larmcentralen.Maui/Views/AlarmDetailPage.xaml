<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:Larmcentralen.Maui.Converters"
             x:Class="Larmcentralen.Maui.Views.AlarmDetailPage"
             BackgroundColor="{StaticResource Background}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <conv:SeverityToBackgroundConverter x:Key="SevBg" />
        <conv:SeverityToTextColorConverter x:Key="SevText" />
        <conv:SeverityToIconConverter x:Key="SevIcon" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" Padding="24,16" ColumnDefinitions="Auto,*">
            <Label Text="← Tillbaka" 
                   TextColor="{StaticResource Accent}" 
                   FontSize="15"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>
        
        <ScrollView Grid.Row="1">
            <Grid HorizontalOptions="Fill">
                <VerticalStackLayout WidthRequest="900" HorizontalOptions="Center" Padding="32,160,32,48" Spacing="0">

                    <!-- Title row with severity inline -->
                    <HorizontalStackLayout Spacing="14" Margin="0,0,0,6">
                        <Label x:Name="TitleLabel" 
                               FontSize="28" 
                               FontAttributes="Bold" 
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center" />
                        <Border x:Name="SeverityBadge"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 6"
                                Padding="10,6"
                                VerticalOptions="Center">
                            <Label x:Name="SeverityLabel" FontSize="13" FontAttributes="Bold" />
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Metadata tight under title -->
                    <HorizontalStackLayout Spacing="6" Margin="0,0,0,12">
                        <Label x:Name="AlarmCodeLabel" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label Text="·" FontSize="14" TextColor="{StaticResource TextSecondary}" />
                        <Label x:Name="EquipmentLabel" 
                               FontSize="14" 
                               TextColor="{StaticResource TextSecondary}" />
                    </HorizontalStackLayout>

                    <!-- Description tight under metadata -->
                    <Label x:Name="DescriptionLabel" 
                           Style="{StaticResource Body}" 
                           LineHeight="1.5" />

                    <!-- Strong section break -->
                    <BoxView HeightRequest="1" 
                             Color="{StaticResource Border}" 
                             Margin="0,32,0,24" />

                    <!-- Solutions header -->
                    <HorizontalStackLayout Spacing="12" Margin="0,0,0,16">
                        <Label Text="LÖSNINGAR" 
                               FontSize="13" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}"
                               CharacterSpacing="1.5"
                               VerticalOptions="Center" />
                        <Button Text="+ Ny lösning"
                                FontSize="13"
                                TextColor="{StaticResource Accent}"
                                BackgroundColor="Transparent"
                                BorderColor="{StaticResource Accent}"
                                BorderWidth="1"
                                CornerRadius="6"
                                HeightRequest="32"
                                Padding="12,0"
                                Clicked="OnAddSolution" />
                        <Button Text="Exportera .docx"
                                FontSize="13"
                                TextColor="{StaticResource Primary}"
                                BackgroundColor="Transparent"
                                BorderColor="{StaticResource Primary}"
                                BorderWidth="1"
                                CornerRadius="6"
                                HeightRequest="32"
                                Padding="12,0"
                                Clicked="OnExport" />
                    </HorizontalStackLayout>

                    <CollectionView x:Name="SolutionsList"
                                    SelectionMode="Single"
                                    SelectionChanged="OnSolutionSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="White"
                                        Stroke="{StaticResource Border}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="18,16"
                                        Margin="0,4"
                                        MinimumHeightRequest="64">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout VerticalOptions="Center" Spacing="3" Grid.Column="0">
                                            <Label Text="{Binding Title}" 
                                                   FontSize="16" 
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Primary}" />
                                            <Label Text="{Binding EstimatedTime}" 
                                                   FontSize="12" 
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>
                                        <Label Text="›" 
                                               FontSize="22" 
                                               TextColor="{StaticResource Border}"
                                               VerticalOptions="Center" 
                                               Grid.Column="1" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Inga lösningar dokumenterade ännu"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}"
                                   Margin="0,8" />
                        </CollectionView.EmptyView>
                    </CollectionView>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>