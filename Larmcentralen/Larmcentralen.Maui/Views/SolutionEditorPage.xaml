<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Larmcentralen.Maui.Views.SolutionEditorPage"
             BackgroundColor="{StaticResource Background}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <Grid Grid.Row="0" Padding="24,16" ColumnDefinitions="Auto,*,Auto">
        <Label Text="← Avbryt" 
               TextColor="{StaticResource TextSecondary}" 
               FontSize="15"
               VerticalOptions="Center"
               Grid.Column="0">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCancelTapped" />
            </Label.GestureRecognizers>
        </Label>
        <Label Text="Redigera lösning" 
               FontSize="18" 
               FontAttributes="Bold"
               TextColor="{StaticResource Primary}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Grid.Column="1" />
        <Button Text="Spara"
                Style="{StaticResource PrimaryButton}"
                WidthRequest="100"
                HeightRequest="40"
                FontSize="14"
                Clicked="OnSaveTapped"
                Grid.Column="2" />
    </Grid>

    <!-- Content -->
    <Grid Grid.Row="1" Style="{StaticResource ContentContainer}" RowDefinitions="Auto,*">

        <!-- Meta fields -->
        <Grid Grid.Row="0"
              Padding="0,0,0,16"
              ColumnDefinitions="*,200"
              ColumnSpacing="16">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="Titel" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                <Entry x:Name="TitleEntry"
                       Placeholder="Lösningens titel..."
                       PlaceholderColor="{StaticResource TextSecondary}"
                       TextColor="{StaticResource Primary}"
                       FontSize="15" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="4">
                <Label Text="Uppskattad tid" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                <Entry x:Name="TimeEntry"
                       Placeholder="t.ex. 15-30 min"
                       PlaceholderColor="{StaticResource TextSecondary}"
                       TextColor="{StaticResource Primary}"
                       FontSize="15" />
            </VerticalStackLayout>
        </Grid>

        <!-- Editor -->
        <Grid x:Name="EditorContainer" Grid.Row="1" />

    </Grid>

    <!-- Status -->
    <Label x:Name="StatusLabel"
           Grid.Row="2"
           FontSize="12"
           TextColor="{StaticResource TextSecondary}"
           HorizontalOptions="Center"
           Margin="0,8,0,16" />

</Grid>

</ContentPage>