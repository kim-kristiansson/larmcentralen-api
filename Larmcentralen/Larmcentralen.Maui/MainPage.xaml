<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:Larmcentralen.Maui.Converters"
             x:Class="Larmcentralen.Maui.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <conv:SeverityToBackgroundConverter x:Key="SevBg" />
        <conv:SeverityToTextColorConverter x:Key="SevText" />
        <conv:SeverityToIconConverter x:Key="SevIcon" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header + Search -->
        <VerticalStackLayout Grid.Row="0" 
                             HorizontalOptions="Center"
                             Spacing="0"
                             Padding="32,48,32,24">

            <!-- Identity -->
            <Label Text="Larmcentralen" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Accent}" 
                   HorizontalOptions="Center" />
            <Label Text="Larmkunskap för värmebehandling"
                   FontSize="14"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   Margin="0,4,0,0" />
            <Label Text="Värnamo • Internt system"
                   FontSize="12"
                   TextColor="{StaticResource Border}"
                   HorizontalOptions="Center"
                   Margin="0,2,0,24" />

            <!-- Search bar -->
            <SearchBar x:Name="SearchEntry"
                       Placeholder="Sök larm, utrustning, område eller kod..."
                       PlaceholderColor="{StaticResource TextSecondary}"
                       TextColor="{StaticResource Primary}"
                       FontSize="15"
                       WidthRequest="600"
                       TextChanged="OnSearchTextChanged"
                       SearchButtonPressed="OnSearch" />

            <!-- Filter row -->
            <Grid ColumnDefinitions="*,*,*"
                  ColumnSpacing="12"
                  WidthRequest="600"
                  Margin="0,16,0,0">

                <!-- Area -->
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Område" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    <Picker x:Name="AreaPicker"
                            TextColor="{StaticResource Primary}"
                            FontSize="13"
                            SelectedIndexChanged="OnAreaFilterChanged" />
                </VerticalStackLayout>

                <!-- Equipment -->
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Utrustning" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    <Picker x:Name="EquipmentPicker"
                            TextColor="{StaticResource Primary}"
                            FontSize="13"
                            SelectedIndexChanged="OnEquipmentFilterChanged" />
                </VerticalStackLayout>

                <!-- Severity -->
                <VerticalStackLayout Grid.Column="2" Spacing="2">
                    <Label Text="Allvarlighetsgrad" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    <Picker x:Name="SeverityFilterPicker"
                            TextColor="{StaticResource Primary}"
                            FontSize="13"
                            SelectedIndexChanged="OnSeverityFilterChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Alla</x:String>
                                <x:String>Kritisk</x:String>
                                <x:String>Hög</x:String>
                                <x:String>Medel</x:String>
                                <x:String>Låg</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>

            </Grid>
            
            <Button Text="+ Nytt larm"
                    FontSize="13"
                    TextColor="White"
                    BackgroundColor="{StaticResource Accent}"
                    CornerRadius="8"
                    HeightRequest="36"
                    Padding="16,0"
                    HorizontalOptions="Center"
                    Margin="0,16,0,0"
                    Clicked="OnAddAlarm" />
        </VerticalStackLayout>

        <!-- Results -->
        <VerticalStackLayout Grid.Row="1" Margin="0,0,0,0">
            
            <!-- Result count -->
            <Label x:Name="ResultCount" 
                   FontSize="13" 
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8" />

            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="{StaticResource Accent}"
                               HorizontalOptions="Center"
                               Margin="0,24,0,0" />
            
            <CollectionView x:Name="AlarmList"
                            SelectionMode="Single"
                            SelectionChanged="OnAlarmSelected">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid WidthRequest="900" HorizontalOptions="Center" Padding="16,0">
                            <Border BackgroundColor="White"
                                    Stroke="{StaticResource Border}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="20,16"
                                    Margin="0,4">
                                <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="16">

                                    <!-- Severity color bar -->
                                    <BoxView Grid.Column="0"
                                             WidthRequest="4"
                                             CornerRadius="2"
                                             Color="{Binding Severity, Converter={StaticResource SevText}}"
                                             VerticalOptions="Fill" />

                                    <!-- Content -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                        <Label Text="{Binding Title}" 
                                               FontSize="17" 
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding AlarmCode}" 
                                                   FontSize="13" 
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextSecondary}" />
                                            <Label Text="·" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                            <Label FontSize="13" TextColor="{StaticResource TextSecondary}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding AreaTitle}" />
                                                        <Span Text=" → " />
                                                        <Span Text="{Binding EquipmentTitle}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Severity badge -->
                                    <Border Grid.Column="2"
                                            BackgroundColor="{Binding Severity, Converter={StaticResource SevBg}}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="10,6"
                                            VerticalOptions="Center">
                                        <Label VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
                                               TextColor="{Binding Severity, Converter={StaticResource SevText}}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Severity, Converter={StaticResource SevIcon}}" />
                                                    <Span Text=" " />
                                                    <Span Text="{Binding Severity}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Border>

                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" Margin="0,40" Spacing="6">
                        <Label x:Name="EmptyTitle"
                               Text="Sök efter larmkod, utrustning eller beskrivning"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center" />
                        <Label x:Name="EmptySubtitle"
                               Text="Använd filtren ovan för att hitta rätt larm"
                               FontSize="13"
                               TextColor="{StaticResource Border}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </VerticalStackLayout>

    </Grid>

</ContentPage>