<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Larmcentralen.Maui.MainPage"
             Title="Larmcentralen">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <SearchBar x:Name="SearchBar"
                   Placeholder="Sök alarm..."
                   SearchButtonPressed="OnSearch"
                   TextChanged="OnSearchTextChanged"
                   Grid.Row="0" />

        <CollectionView x:Name="AlarmList"
                        Grid.Row="1"
                        SelectionMode="Single"
                        SelectionChanged="OnAlarmSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12" Margin="0,4" Stroke="LightGray" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" />
                                <Label Text="{Binding AlarmCode}" FontSize="12" TextColor="Gray" />
                                <Label Text="{Binding EquipmentTitle}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Severity}"
                                   FontSize="12" FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>