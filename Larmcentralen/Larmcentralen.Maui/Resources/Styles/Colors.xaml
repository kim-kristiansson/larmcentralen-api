<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="Accent">#C41E2A</Color>
    <Color x:Key="AccentLight">#FEE2E2</Color>

    <!-- Neutrals -->
    <Color x:Key="Primary">#1E293B</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="Surface">#F8FAFC</Color>
    <Color x:Key="Background">#FFFFFF</Color>
    <Color x:Key="Border">#E2E8F0</Color>

    <!-- Severity backgrounds -->
    <Color x:Key="SeverityLågBg">#DBEAFE</Color>
    <Color x:Key="SeverityMedelBg">#FEF3C7</Color>
    <Color x:Key="SeverityHögBg">#FED7AA</Color>
    <Color x:Key="SeverityKritiskBg">#FECACA</Color>

    <!-- Severity text -->
    <Color x:Key="SeverityLågText">#1E40AF</Color>
    <Color x:Key="SeverityMedelText">#92400E</Color>
    <Color x:Key="SeverityHögText">#9A3412</Color>
    <Color x:Key="SeverityKritiskText">#991B1B</Color>

</ResourceDictionary>