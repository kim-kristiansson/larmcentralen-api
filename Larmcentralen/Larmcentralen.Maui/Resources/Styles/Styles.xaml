<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Page title -->
    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
    </Style>

    <!-- Section title -->
    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
    </Style>

    <!-- Card title -->
    <Style x:Key="CardTitle" TargetType="Label">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
    </Style>

    <!-- Body text -->
    <Style x:Key="Body" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
    </Style>

    <!-- Subtitle / metadata -->
    <Style x:Key="Subtitle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <!-- Card container -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="Stroke" Value="{StaticResource Border}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="Margin" Value="0,5" />
    </Style>

    <!-- Divider line -->
    <Style x:Key="Divider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="Color" Value="{StaticResource Border}" />
        <Setter Property="Margin" Value="0,8" />
    </Style>

    <!-- Header bar -->
    <Style x:Key="HeaderBar" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="Padding" Value="20,18" />
        <Setter Property="MinimumHeightRequest" Value="56" />
    </Style>

    <!-- Header bar title -->
    <Style x:Key="HeaderTitle" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- Primary button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- Search bar -->
    <Style x:Key="AppSearchBar" TargetType="SearchBar">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>
    
    <Style x:Key="ContentContainer" TargetType="Grid">
        <Setter Property="WidthRequest" Value="900" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Padding" Value="32,0" />
    </Style>
</ResourceDictionary>